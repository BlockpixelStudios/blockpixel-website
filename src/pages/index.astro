---
import BaseLayout from '../layouts/BaseLayout.astro';
import GlassCard from '../components/GlassCard.astro';
---
<BaseLayout title="Blockpixel Studios">
  <section class="grid md:grid-cols-2 gap-8 items-center">
    <div>
      <h1 class="text-4xl md:text-6xl font-extrabold">Criando experiências que conectam jogadores e comunidades.</h1>
      <p class="mt-4 text-lg text-white/90">Blockpixel Studios — mods, servidores, ferramentas e plataformas.</p>
      <div class="mt-6 flex gap-3">
        <a class="px-6 py-3 rounded bg-cyan-600" href="/projects">Ver projetos</a>
        <a class="px-6 py-3 rounded bg-white/6" href="/login">Entrar</a>
      </div>
    </div>

    <div>
      <GlassCard title="Projeto em destaque">
        <img src="/hero-preview.png" alt="project" class="w-full h-48 object-cover rounded" />
        <p class="mt-3 text-sm">UNIVERSE roleplay — mapa e servidor RP.</p>
      </GlassCard>
    </div>
  </section>
</BaseLayout>
