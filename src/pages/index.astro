---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Blockpixel Studios">
  <section class="grid md:grid-cols-2 gap-8 items-center">
    <div>
      <h1 class="text-4xl md:text-6xl font-extrabold">Criando experiências que conectam jogadores e comunidades.</h1>
      <p class="mt-4 text-lg text-white/90">Blockpixel Studios — mods, servidores e ferramentas.</p>
      <div class="mt-6 flex gap-3">
        <a class="btn btn-primary" href="/projects">Ver projetos</a>
        <a class="btn" href="/login">Entrar</a>
      </div>
    </div>
    <div class="glass p-6 rounded">
      <h3 class="text-xl font-semibold">Projeto em destaque</h3>
      <p class="mt-3 text-sm">UNIVERSE roleplay — em desenvolvimento.</p>
    </div>
  </section>
</BaseLayout>
