---
// src/pages/admin/users.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Admin - Usuários">
  <div class="max-w-6xl mx-auto p-4">
    <h1 class="text-2xl font-bold mb-4">Usuários</h1>
    <div class="mb-4">
      <button id="refresh" class="btn">Atualizar</button>
    </div>
    <div id="users-list"></div>
  </div>

  <script type="module">
    import { supabase } from '/src/lib/supabaseClient.js';

    async function listUsers() {
      const { data, error } = await supabase.from('profiles').select('*').order('created_at', { ascending: false });
      const el = document.getElementById('users-list');
      if (error) { el.innerHTML = '<div class="p-3 bg-red-600/10 rounded">Erro: '+error.message+'</div>'; return; }
      el.innerHTML = '';
      (data||[]).forEach(u=>{
        const item = document.createElement('div');
        item.className = 'glass p-3 rounded mb-3 flex justify-between items-center';
        item.innerHTML = `<div><div class="font-semibold">${escapeHtml(u.display_name||u.email||'')}</div><div class="text-xs opacity-80">role: ${escapeHtml(u.role||'user')}</div></div>
                          <div class="flex gap-2">
                            <button data-id="${u.id}" class="btn btn-primary btn-promote">Promover</button>
                            <button data-id="${u.id}" class="btn btn-danger btn-del">Excluir</button>
                          </div>`;
        el.appendChild(item);
      });

      document.querySelectorAll('.btn-promote').forEach(b => b.addEventListener('click', async (e)=>{
        const id = e.currentTarget.dataset.id;
        if (!confirm('Promover para admin?')) return;
        const { error } = await supabase.from('profiles').update({ role: 'admin' }).eq('id', id);
        if (error) alert('Erro: '+error.message); else listUsers();
      }));

      document.querySelectorAll('.btn-del').forEach(b => b.addEventListener('click', async (e)=>{
        const id = e.currentTarget.dataset.id;
        if (!confirm('Excluir profile?')) return;
        const { error } = await supabase.from('profiles').delete().eq('id', id);
        if (error) alert('Erro: '+error.message); else listUsers();
      }));
    }

    function escapeHtml(s){ return (s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"}[c])); }

    document.getElementById('refresh').addEventListener('click', listUsers);
    listUsers();
  </script>
</BaseLayout>
