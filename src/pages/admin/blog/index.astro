---
// src/pages/admin/blog/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Admin - Blog">
  <div class="max-w-6xl mx-auto p-4">
    <h1 class="text-2xl font-bold mb-4">Posts</h1>
    <div class="mb-4">
      <a href="/admin/blog/new" class="btn btn-primary">Novo Post</a>
      <a href="/admin" class="btn">Voltar</a>
    </div>
    <div id="posts-list"></div>
  </div>

  <script type="module">
    import { supabase } from '/src/lib/supabaseClient.js';

    async function listPosts() {
      const { data, error } = await supabase.from('posts').select('*').order('created_at', { ascending: false });
      const container = document.getElementById('posts-list');
      if (error) { container.innerHTML = '<div class="p-3 bg-red-600/10 rounded">Erro: '+error.message+'</div>'; return; }
      container.innerHTML = '';
      (data || []).forEach(p => {
        const el = document.createElement('div');
        el.className = 'glass p-4 rounded mb-3 flex justify-between items-start';
        el.innerHTML = `<div><strong>${escapeHtml(p.title)}</strong><div class="text-sm opacity-80">${escapeHtml(p.excerpt||'')}</div></div>
                        <div class="flex gap-2">
                          <a class="btn" href="/admin/blog/edit/${p.id}">Editar</a>
                          <button class="btn btn-danger" data-id="${p.id}">Excluir</button>
                        </div>`;
        container.appendChild(el);
      });

      document.querySelectorAll('.btn-danger').forEach(b => b.addEventListener('click', async (e) => {
        const id = e.currentTarget.dataset.id;
        if (!confirm('Excluir post?')) return;
        const { error } = await supabase.from('posts').delete().eq('id', id');
        if (error) alert('Erro: '+error.message); else listPosts();
      }));
    }

    function escapeHtml(s){ return (s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"}[c])); }

    listPosts();
  </script>
</BaseLayout>
