---
// src/pages/admin/blog/edit/[id].astro
import BaseLayout from '../../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Editar Post">
  <div class="max-w-4xl mx-auto p-4">
    <h1 class="text-2xl font-bold mb-4">Editar Post</h1>
    <div id="form"></div>
    <a href="/admin/blog" class="btn">Voltar</a>
  </div>

  <script type="module">
    import { supabase } from '/src/lib/supabaseClient.js';
    const parts = location.pathname.split('/');
    const id = parts[parts.length-1];

    function escapeHtml(s){ return (s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"}[c])); }

    async function load() {
      const { data, error } = await supabase.from('posts').select('*').eq('id', id).single();
      const p = data;
      if (error || !p) return document.getElementById('form').innerHTML = '<div>Post não encontrado</div>';

      document.getElementById('form').innerHTML = `
        <input id="title" class="p-3 rounded bg-white/5 mb-2" value="${escapeHtml(p.title)}" />
        <input id="slug" class="p-3 rounded bg-white/5 mb-2" value="${escapeHtml(p.slug)}" />
        <input id="excerpt" class="p-3 rounded bg-white/5 mb-2" value="${escapeHtml(p.excerpt||'')}" />
        <textarea id="content" class="p-3 rounded bg-white/5 h-48">${escapeHtml(p.content||'')}</textarea>
        <div class="flex gap-2 mt-3">
          <button id="btn-save" class="btn btn-primary">Salvar</button>
        </div>
      `;

      document.getElementById('btn-save').addEventListener('click', async () => {
        const body = {
          title: document.getElementById('title').value.trim(),
          slug: document.getElementById('slug').value.trim(),
          excerpt: document.getElementById('excerpt').value.trim(),
          content: document.getElementById('content').value.trim()
        };
        const { error } = await supabase.from('posts').update(body).eq('id', id);
        if (error) alert('Erro: ' + error.message); else location.href = '/admin/blog';
      });
    }

    load();
  </script>
</BaseLayout>
