---
// src/pages/admin/blog/edit/[id].astro
import '../../styles/globals.css';
---
<html><head><meta charset="utf-8"/></head>
<body class="min-h-screen bg-gradient-to-b from-black to-deepblue text-white">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold mb-4">Editar Post</h1>
    <div id="form"></div>
    <a href="/admin/blog" class="btn">Voltar</a>
  </div>

  <script type="module">
    import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm';
    const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
    const id = location.pathname.split('/').pop();

    async function token() { const { data } = await supabase.auth.getSession(); return data?.session?.access_token ?? null; }

    async function load() {
      const tk = await token();
      const res = await fetch('/api/admin/posts', { headers: { Authorization: 'Bearer ' + tk }});
      const j = await res.json();
      const p = (j.posts||[]).find(x => x.id === id);
      if (!p) return document.getElementById('form').innerHTML = '<div>Post não encontrado</div>';

      document.getElementById('form').innerHTML = `
        <input id="title" class="p-3 rounded bg-white/5 mb-2" value="${escapeHtml(p.title)}" />
        <input id="slug" class="p-3 rounded bg-white/5 mb-2" value="${escapeHtml(p.slug)}" />
        <input id="excerpt" class="p-3 rounded bg-white/5 mb-2" value="${escapeHtml(p.excerpt||'')}" />
        <textarea id="content" class="p-3 rounded bg-white/5 h-48">${escapeHtml(p.content||'')}</textarea>
        <div class="flex gap-2 mt-3">
          <button id="btn-save" class="btn btn-primary">Salvar</button>
        </div>
      `;

      document.getElementById('btn-save').addEventListener('click', async () => {
        const body = {
          title: document.getElementById('title').value.trim(),
          slug: document.getElementById('slug').value.trim(),
          excerpt: document.getElementById('excerpt').value.trim(),
          content: document.getElementById('content').value.trim()
        };
        const tk2 = await token();
        const r = await fetch('/api/admin/posts/' + id, { method: 'PUT', headers: { 'Content-Type':'application/json', Authorization: 'Bearer ' + tk2 }, body: JSON.stringify(body) });
        if (r.ok) location.href = '/admin/blog'; else { const jj = await r.json(); alert(jj.error || 'Erro'); }
      });
    }

    function escapeHtml(s){ return (s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"}[c])); }

    load();
  </script>
</body></html>
