---
// src/pages/admin/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabaseClient';
import { onMount } from 'astro/jsx-runtime';
---
<BaseLayout title="Painel Admin">
  <div class="max-w-6xl mx-auto p-4">
    <h1 class="text-3xl font-bold mb-4">Painel Admin</h1>
    <div id="status" class="mb-4"></div>

    <div class="flex gap-3 mb-6">
      <a href="/admin/blog" class="btn btn-primary">Blog</a>
      <a href="/admin/users" class="btn">Usuários</a>
      <a href="/logout" class="btn">Sair</a>
    </div>
  </div>

  <script type="module">
    import { supabase } from '/src/lib/supabaseClient.js';

    async function checkAdmin() {
      const { data } = await supabase.auth.getSession();
      const userId = data?.session?.user?.id;
      if (!userId) {
        document.getElementById('status').innerHTML = '<div class="p-3 bg-yellow-600/10 rounded">Faça login em <a href="/login" class="underline">/login</a></div>';
        return;
      }
      const { data: profile, error } = await supabase.from('profiles').select('role,email').eq('auth_id', userId).single();
      if (error || !profile) {
        document.getElementById('status').innerHTML = '<div class="p-3 bg-red-600/10 rounded">Perfil não encontrado. Adicione o profile no Supabase.</div>';
        return;
      }
      if (profile.role !== 'admin') {
        document.getElementById('status').innerHTML = '<div class="p-3 bg-red-600/10 rounded">Acesso negado. Você não é admin.</div>';
        return;
      }
      document.getElementById('status').innerHTML = '<div class="p-3 bg-green-600/10 rounded">Bem-vindo, admin: ' + (profile.email||'') + '</div>';
    }

    checkAdmin();
  </script>
</BaseLayout>
