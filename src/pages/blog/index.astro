---
// src/pages/blog/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { marked } from 'marked';
import { supabase } from '/src/lib/supabase.js';
const { data: posts } = await supabase.from('posts').select('id,title,slug,excerpt,created_at').order('created_at', { ascending: false });
---
<BaseLayout title="Blog">
  <h1 class="text-3xl font-bold mb-6">Blog</h1>
  <div class="grid md:grid-cols-2 gap-6">
    {posts?.map(p => (
      <article class="glass p-4 rounded">
        <h2 class="text-xl font-semibold"><a href={`/blog/${p.slug}`}>{p.title}</a></h2>
        <p class="text-sm opacity-80 mt-2">{p.excerpt}</p>
      </article>
    ))}
  </div>
</BaseLayout>
