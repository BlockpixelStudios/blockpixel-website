---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/globals.css';
import { onMount } from 'solid-js'; // not required; we'll use script
---
<BaseLayout title="Login">
  <section class="max-w-xl mx-auto p-8">
    <h1 class="text-2xl font-bold mb-4">Entrar / Criar conta</h1>

    <form id="login-form" class="grid gap-3">
      <input id="email" type="email" placeholder="seu@email.com"
             class="p-3 rounded bg-white/5" required />
      <div class="flex gap-2">
        <button type="button" id="signup" class="px-4 py-2 bg-cyan-600 rounded">Criar conta</button>
        <button type="button" id="signin" class="px-4 py-2 bg-white/6 rounded">Entrar</button>
      </div>
      <p id="msg" class="mt-3 text-sm"></p>
    </form>

    <script type="module">
      import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm';
      const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);

      document.getElementById('signup').addEventListener('click', async () => {
        const email = document.getElementById('email').value;
        const { data, error } = await supabase.auth.signUp({ email, password: Math.random().toString(36).slice(-8) });
        document.getElementById('msg').innerText = error ? error.message : 'Conta criada! Verifique seu e-mail.';
      });

      document.getElementById('signin').addEventListener('click', async () => {
        const email = document.getElementById('email').value;
        const { data, error } = await supabase.auth.signInWithOtp({ email, options: { emailRedirectTo: window.location.origin + '/admin' } });
        document.getElementById('msg').innerText = error ? error.message : 'Link enviado! Verifique o e-mail.';
      });
    </script>
  </section>
</BaseLayout>
