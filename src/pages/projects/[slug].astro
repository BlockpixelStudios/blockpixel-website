---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '/src/lib/supabase.js';
const { slug } = Astro.params;
const { data: project } = await supabase.from('projects').select('*').eq('slug', slug).single();
---
<BaseLayout title={project?.title || 'Projeto'}>
  {project ? (
    <>
      <h1 class="text-4xl font-bold">{project.title}</h1>
      <p class="mt-3 text-white/80">{project.summary}</p>
      <article class="mt-6 prose prose-invert max-w-none">
        <!-- content saved as Markdown or HTML — if Markdown convert on server or in client -->
        <div innerHTML={project.content}></div>
      </article>
    </>
  ) : (
    <p>Projeto não encontrado.</p>
  )}
</BaseLayout>
