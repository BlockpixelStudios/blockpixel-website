---
// src/layouts/BaseLayout.astro
import '../styles/globals.css';
const { title = 'Blockpixel Studios' } = Astro.props;
---
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="blob left-blob"></div>
    <div class="blob right-blob"></div>

    <header class="glass p-3 sticky top-0 z-40">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
          <img src="/logo-short.png" alt="logo" class="w-10 h-10" />
          <div class="hidden sm:block">
            <div class="font-semibold">Blockpixel Studios</div>
            <div class="text-xs text-white/70">Tech · Jogos · Comunidade</div>
          </div>
        </a>
        <nav class="flex gap-4">
          <a href="/projects">Projetos</a>
          <a href="/blog">Blog</a>
          <a href="/login" class="btn">Entrar</a>
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-10">
      <slot />
    </main>

    <footer class="mt-12 text-sm text-white/70 text-center py-6">
      © {new Date().getFullYear()} Blockpixel Studios
    </footer>
  </body>
</html>
